# Required: full origin of the Peach API. No trailing slash, no /v1 suffix.
# Examples:
#   https://api.peachbitcoin.com         (mainnet)
#   https://api-regtest.peachbitcoin.com (regtest)
VITE_API_URL=https://api-regtest.peachbitcoin.com

# Required: which Bitcoin chain the wallet/UI should treat as canonical.
# Acceptable values: BITCOIN | REGTEST
# This governs address validation, deeplink scheme, and any chain-conditional UI.
# It is independent from VITE_API_URL — pointing at a regtest API while choosing
# BITCOIN (or vice versa) is a configuration mistake, not a codebase concern.
VITE_BITCOIN_NETWORK=REGTEST

# Optional: enable in-app developer tools. Only takes effect when
# VITE_BITCOIN_NETWORK=REGTEST. NEVER set in production builds.
# VITE_DEV_TOOLS=1
