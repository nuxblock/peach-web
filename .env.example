VITE_API_BASE=/api

# VITE_DEV_TOOLS=1   # Enable in-app developer tools (regtest only).
                     # Adds Settings → Developer Tools → BIP322 Message Signer.
                     # NEVER set in production builds — production GitHub Actions
                     # must not export this variable. The flag is also gated at
                     # runtime to require a tpub-prefixed (regtest) xpub.
